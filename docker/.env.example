# Copie para .env e preencha os valores antes de subir o stack.
# cp .env.example .env

# Grafana (obrigatório — autenticação habilitada)
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=altere-esta-senha-forte
GRAFANA_PORT=3000
GRAFANA_ROOT_URL=http://localhost:3000

# Booptube Web
BOOPTUBE_PORT=8080
BOOPTUBE_MAX_CONCURRENT=4
BOOPTUBE_FILE_TTL=10m
BOOPTUBE_DOWNLOAD_TIMEOUT=30m
GOMEMLIMIT=1800MiB

# Build args (opcional)
BOOPTUBE_VERSION=dev
BOOPTUBE_COMMIT=none
BOOPTUBE_DATE=unknown
